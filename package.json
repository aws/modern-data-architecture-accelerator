{
  "name": "@aws-mdaa/mdaa",
  "private": true,
  "bin": "./packages/cli/bin/mdaa",
  "version": "1.5.0",
  "license": "Apache-2.0",
  "scripts": {
    "git-clean": "git clean -Xfd -e !development -e !development/** -e !.vscode -e !.vscode/** -e !.idea -e !.idea/**",
    "build": "./scripts/build/build.sh",
    "build:all": "npx nx run-many -t build --all --skip-nx-cache",
    "lint": "./scripts/quality/lint.sh",
    "lint:all": "npx nx run-many -t lint --all --skip-nx-cache",
    "prepare": "husky install source/.husky",
    "prepush": "./scripts/quality/prepush.sh",
    "prepush:all": "./scripts/quality/prepush.sh --all",
    "prettier": "./scripts/quality/prettier.sh",
    "prettier:all": "npx nx run-many -t prettier --all --skip-nx-cache",
    "test": "./scripts/test/test.sh",
    "test:all": "npx nx run-many -t test --all --skip-nx-cache",
    "test:update-baselines": "UPDATE_BASELINES=true ./scripts/test/test.sh",
    "test:python": "./scripts/test/test_python.sh",
    "test:python:install": "./scripts/test/test_python_install.sh",
    "test:python:all": "./scripts/test/python_test.sh",
    "delete:snapshots": "find . -path '*/__snapshots__/*.snap' -type f -delete",
    "postinstall": "sed -i 's/\"inBundle\": true,//g' package-lock.json 2>/dev/null || sed -i '' 's/\"inBundle\": true,//g' package-lock.json 2>/dev/null || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --max-warnings 0"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/js-yaml": "4.0.9",
    "@typescript-eslint/eslint-plugin": "8.50.0",
    "@typescript-eslint/parser": "8.50.0",
    "core-js-pure": "3.43.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.5.0",
    "eslint-plugin-prettier": "5.5.4",
    "husky-init": "8.0.0",
    "jest": "29.7.0",
    "js-yaml": "4.1.1",
    "jsii": "5.9.20",
    "jsii-config": "1.121.0",
    "jsii-pacmak": "1.121.0",
    "lint-staged": "16.2.7",
    "prettier": "3.7.4",
    "ts-node": "10.9.2",
    "typedoc": "0.28.17"
  },
  "optionalDependencies": {
    "@nx/nx-darwin-arm64": "22.5.4",
    "@nx/nx-darwin-x64": "22.5.4",
    "@nx/nx-freebsd-x64": "22.5.4",
    "@nx/nx-linux-arm-gnueabihf": "22.5.4",
    "@nx/nx-linux-arm64-gnu": "22.5.4",
    "@nx/nx-linux-arm64-musl": "22.5.4",
    "@nx/nx-linux-x64-gnu": "22.5.4",
    "@nx/nx-linux-x64-musl": "22.5.4",
    "@nx/nx-win32-arm64-msvc": "22.5.4",
    "@nx/nx-win32-x64-msvc": "22.5.4"
  },
  "dependencies": {
    "aws-cdk": "2.1034.0",
    "lerna": "9.0.7",
    "nx": "22.5.4",
    "typescript": "5.9.3"
  },
  "workspaces": [
    "packages/cli",
    "packages/constructs/L2/*",
    "packages/constructs/L3/*/*",
    "packages/utilities/*",
    "packages/apps/*/*",
    "schemas",
    "integ/constructs"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aws/modern-data-architecture-accelerator"
  }
}
