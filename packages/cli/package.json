{
  "name": "@aws-mdaa/cli",
  "version": "1.5.0",
  "description": "Modern Data Architecture Accelerator (MDAA) CLI",
  "license": "Apache-2.0",
  "author": {
    "name": "Amazon Web Services",
    "url": "https://aws.amazon.com/solutions"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aws/modern-data-architecture-accelerator"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "bin": {
    "mdaa": "./bin/mdaa"
  },
  "scripts": {
    "build": "tsc && typescript-json-schema --required --noExtraProps tsconfig.json MdaaConfigContents --include 'lib/*.ts' --include '../../node_modules/@types/**/*.ts' --include 'lib/config-schema.json' > lib/config-schema.json && cp lib/config-schema.json ../../schemas/${npm_package_name}.json",
    "watch": "tsc -w",
    "test": "jest --passWithNoTests --testPathIgnorePatterns='.*\\.snapshot\\.test\\.ts'",
    "lint": "eslint --max-warnings 0 -c ../../eslint.config.mjs",
    "test:coverage": "jest --passWithNoTests --coverage --testPathIgnorePatterns='.*\\.snapshot\\.test\\.ts'",
    "test:snapshots": "jest --passWithNoTests --testPathPattern='.*\\.snapshot\\.test\\.ts'",
    "test:snapshots:update": "jest --passWithNoTests --testPathPattern='.*\\.snapshot\\.test\\.ts' --updateSnapshot"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "22.9.0",
    "@types/prettier": "2.6.0",
    "jest": "29.7.0",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-json-schema": "0.67.1"
  },
  "dependencies": {
    "@aws-mdaa/config": "1.5.0",
    "@aws-mdaa/devops": "1.5.0",
    "ajv": "8.17.1",
    "command-exists": "1.2.9",
    "command-line-args": "5.2.1",
    "yaml": "1.10.2"
  },
  "gitHead": "8b49a2b371014baec046605ffdbfe38951099c31"
}
